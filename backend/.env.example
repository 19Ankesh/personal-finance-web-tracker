# ──────────────────────────────────────────────────────────────────────────────
# FinSense Backend – Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local dev example:  postgresql://postgres:password@localhost:5432/finsense
# Supabase example:   postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/finsense

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# JWT algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# Token expiry in days
ACCESS_TOKEN_EXPIRE_DAYS=7
